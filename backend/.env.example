# ─────────────────────────────────────────────────────────────────────────────
#  SBE Annex Backend — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local MongoDB (recommended for VPS):
MONGO_URL=mongodb://localhost:27017
# MongoDB Atlas (recommended for cloud hosting):
# MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/sbe_annex?retryWrites=true&w=majority

DB_NAME=sbe_annex

# ── JWT / Security ────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=change-me-use-a-long-random-string-at-least-48-chars
ALGORITHM=HS256
# Token lifetime in minutes (7200 = 5 days)
ACCESS_TOKEN_EXPIRE_MINUTES=7200

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3192
# The public URL of this backend (used in email links)
BASE_URL=https://your-backend-domain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of your deployed frontend (used in verification email links)
FRONTEND_URL=https://your-frontend-domain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Include http://localhost:5173 for local development.
CORS_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# ── Email — Resend ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free plan includes 3,000 emails/month.
# You must verify a domain or use the @resend.dev sandbox for testing.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=SBE Annex <noreply@yourdomain.com>
RESEND_REPLY_TO=support@yourdomain.com

# ── SMS CONFIGURATION (Kenya) ─────────────────────────────────────────────────────────
SMS_API_KEY=your_sms_api_key
SMS_API_URL=your_sms_api_url
SMS_SENDER_ID=YOURNAME

# ── Branding ──────────────────────────────────────────────────────────────────
BRAND_COLOR=#16a34a
APP_NAME=SBE Annex

# ── Verification cooldown ─────────────────────────────────────────────────────
# Minimum seconds between verification code resending requests
RESEND_COOLDOWN_SECONDS=60
